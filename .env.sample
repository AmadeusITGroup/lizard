# ============================================================
# LIZARD Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# --- Database ---
LIZARD_DB_URL=sqlite+aiosqlite:///./lizard.db

# --- AI/LLM (Optional - for AI-assisted mapping) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Ollama (alternative to OpenAI)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# --- UI Configuration ---
VITE_API_BASE=http://localhost:8000

# --- Production Settings (Docker) ---
# Uncomment for production deployment
# LIZARD_DB_URL=postgresql+asyncpg://user:pass@db:5432/lizard
# VITE_API_BASE=https://api.yourdomain.com

# ============================================================
# Cloud Mode (Optional — all values below are only needed for
# cloud/Databricks mode. Local mode works without any of them.)
# ============================================================

# --- Mode ---
# Set to "cloud" to enable cloud data sources and Databricks execution.
# Default is "local" (all computation stays on the local machine).
# LIZARD_MODE=local

# --- Cloud Config File ---
# Path to YAML config for gateways, connections, and clusters.
# Default: lizard-cloud.yaml in the project root.
# LIZARD_CLOUD_CONFIG_PATH=lizard-cloud.yaml

# --- Azure Service Principal (used as fallback when config fields are empty) ---
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=